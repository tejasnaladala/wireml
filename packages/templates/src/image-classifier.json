{
  "version": 1,
  "name": "Image classifier",
  "description": "Live webcam → CLIP features → linear head → preview. The WireML take on Teachable Machine's default project.",
  "nodes": [
    {
      "id": "n_webcam",
      "schemaId": "data.webcam",
      "position": { "x": 40, "y": 200 },
      "params": { "captureMode": "manual", "width": 224, "height": 224 }
    },
    {
      "id": "n_upload",
      "schemaId": "data.upload",
      "position": { "x": 40, "y": 440 },
      "params": { "classes": ["wrapped", "unwrapped"] }
    },
    {
      "id": "n_clip",
      "schemaId": "backbone.clip.vit-b-32",
      "position": { "x": 360, "y": 320 },
      "params": { "normalize": true }
    },
    {
      "id": "n_linear",
      "schemaId": "head.linear",
      "position": { "x": 680, "y": 320 },
      "params": { "epochs": 50, "learningRate": 0.001, "batchSize": 16 }
    },
    {
      "id": "n_preview",
      "schemaId": "deploy.preview",
      "position": { "x": 1000, "y": 200 },
      "params": { "showBars": true, "topK": 3 }
    },
    {
      "id": "n_confusion",
      "schemaId": "eval.confusion",
      "position": { "x": 1000, "y": 440 },
      "params": {}
    }
  ],
  "edges": [
    { "id": "e1", "source": { "nodeId": "n_upload", "port": "images" }, "target": { "nodeId": "n_clip", "port": "images" } },
    { "id": "e2", "source": { "nodeId": "n_webcam", "port": "frames" }, "target": { "nodeId": "n_clip", "port": "images" } },
    { "id": "e3", "source": { "nodeId": "n_clip", "port": "features" }, "target": { "nodeId": "n_linear", "port": "features" } },
    { "id": "e4", "source": { "nodeId": "n_upload", "port": "labels" }, "target": { "nodeId": "n_linear", "port": "labels" } },
    { "id": "e5", "source": { "nodeId": "n_linear", "port": "model" }, "target": { "nodeId": "n_preview", "port": "model" } },
    { "id": "e6", "source": { "nodeId": "n_clip", "port": "features" }, "target": { "nodeId": "n_preview", "port": "features" } },
    { "id": "e7", "source": { "nodeId": "n_linear", "port": "model" }, "target": { "nodeId": "n_confusion", "port": "model" } },
    { "id": "e8", "source": { "nodeId": "n_clip", "port": "features" }, "target": { "nodeId": "n_confusion", "port": "features" } },
    { "id": "e9", "source": { "nodeId": "n_upload", "port": "labels" }, "target": { "nodeId": "n_confusion", "port": "labels" } }
  ],
  "meta": {
    "tags": ["beginner", "image", "webcam"]
  }
}
