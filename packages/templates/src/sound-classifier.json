{
  "version": 1,
  "name": "Sound classifier",
  "description": "Microphone → Whisper encoder → k-NN head → live preview.",
  "nodes": [
    {
      "id": "n_mic",
      "schemaId": "data.mic",
      "position": { "x": 40, "y": 200 },
      "params": { "sampleRate": 16000, "durationMs": 2000 }
    },
    {
      "id": "n_whisper",
      "schemaId": "backbone.whisper.tiny",
      "position": { "x": 360, "y": 200 },
      "params": {}
    },
    {
      "id": "n_knn",
      "schemaId": "head.knn",
      "position": { "x": 680, "y": 200 },
      "params": { "k": 5, "metric": "cosine" }
    },
    {
      "id": "n_preview",
      "schemaId": "deploy.preview",
      "position": { "x": 1000, "y": 200 },
      "params": { "showBars": true, "topK": 3 }
    }
  ],
  "edges": [
    { "id": "e1", "source": { "nodeId": "n_mic", "port": "clips" }, "target": { "nodeId": "n_whisper", "port": "audio" } },
    { "id": "e2", "source": { "nodeId": "n_whisper", "port": "features" }, "target": { "nodeId": "n_knn", "port": "features" } },
    { "id": "e3", "source": { "nodeId": "n_knn", "port": "model" }, "target": { "nodeId": "n_preview", "port": "model" } },
    { "id": "e4", "source": { "nodeId": "n_whisper", "port": "features" }, "target": { "nodeId": "n_preview", "port": "features" } }
  ],
  "meta": {
    "tags": ["beginner", "audio", "mic"]
  }
}
