{
  "version": 1,
  "name": "Pose classifier",
  "description": "Webcam → MediaPipe Pose landmarks → Linear head → preview.",
  "nodes": [
    {
      "id": "n_webcam",
      "schemaId": "data.webcam",
      "position": { "x": 40, "y": 200 },
      "params": { "captureMode": "continuous", "width": 640, "height": 480 }
    },
    {
      "id": "n_upload",
      "schemaId": "data.upload",
      "position": { "x": 40, "y": 440 },
      "params": { "classes": ["standing", "sitting", "waving"] }
    },
    {
      "id": "n_pose",
      "schemaId": "backbone.mediapipe.pose",
      "position": { "x": 360, "y": 320 },
      "params": { "modelComplexity": "lite" }
    },
    {
      "id": "n_linear",
      "schemaId": "head.linear",
      "position": { "x": 680, "y": 320 },
      "params": { "epochs": 80, "learningRate": 0.002, "batchSize": 32 }
    },
    {
      "id": "n_preview",
      "schemaId": "deploy.preview",
      "position": { "x": 1000, "y": 200 },
      "params": { "showBars": true, "topK": 3 }
    }
  ],
  "edges": [
    { "id": "e1", "source": { "nodeId": "n_webcam", "port": "frames" }, "target": { "nodeId": "n_pose", "port": "images" } },
    { "id": "e2", "source": { "nodeId": "n_upload", "port": "images" }, "target": { "nodeId": "n_pose", "port": "images" } },
    { "id": "e3", "source": { "nodeId": "n_pose", "port": "features" }, "target": { "nodeId": "n_linear", "port": "features" } },
    { "id": "e4", "source": { "nodeId": "n_upload", "port": "labels" }, "target": { "nodeId": "n_linear", "port": "labels" } },
    { "id": "e5", "source": { "nodeId": "n_linear", "port": "model" }, "target": { "nodeId": "n_preview", "port": "model" } },
    { "id": "e6", "source": { "nodeId": "n_pose", "port": "features" }, "target": { "nodeId": "n_preview", "port": "features" } }
  ],
  "meta": {
    "tags": ["beginner", "pose", "webcam"]
  }
}
